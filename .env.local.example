# GoldenLink - 지능형 응급 병원 매칭 시스템
# 이 파일을 .env.local로 복사 후 값을 채워주세요.
# cp .env.local.example .env.local

# ── AI 증상 분석 (선택, 권장) ──
# Gemini 우선 사용 → Claude fallback → 키워드 기반 fallback 순서로 동작
# 무료 tier가 큰 Gemini 추천 (15 RPM, 1500 RPD)
# 발급: https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Anthropic Claude API 키 (선택, fallback용)
# 발급: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── 지도 API (선택) ──
# 네이버 지도 API (NCP 클라이언트 ID)
# https://console.ncloud.com → AI·Application Service → Maps 에서 발급
NEXT_PUBLIC_NAVER_MAP_KEY=your_ncp_key_id

# 카카오 지도 API (네이버 대체용)
# https://developers.kakao.com/ 에서 발급
# NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_key

# ── 데이터베이스 (필수, 출시 전 영속화 위해) ──
# Supabase 프로젝트 → Settings → API에서 복사
# https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
